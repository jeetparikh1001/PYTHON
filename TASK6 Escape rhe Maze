from typing import List, Dict
from enum import Enum


class Position:
    image: str
    x: int
    y: int

    def __init__(self, image: str, x: int, y: int) -> None:
        self.image = image
        self.x = x
        self.y = y


class Goal:
    possible_final_positions: List[List[int]]
    position: Position

    def __init__(self, possible_final_positions: List[List[int]], position: Position) -> None:
        self.possible_final_positions = possible_final_positions
        self.position = position


