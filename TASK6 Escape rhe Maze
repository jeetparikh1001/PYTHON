class TraceHistory:
    color: str
    thickness: int
    prev_x: int
    x: int
    prev_y: int
    y: int
    grid_x: int
    grid_y: int

    def __init__(self, color: str, thickness: int, prev_x: int, x: int, prev_y: int, y: int, grid_x: int, grid_y: int) -> None:
        self.color = color
        self.thickness = thickness
        self.prev_x = prev_x
        self.x = x
        self.prev_y = prev_y
        self.y = y
        self.grid_x = grid_x
        self.grid_y = grid_y


class Robot:
    x: int
    y: int
    objects: Objects
    model: str
    orientation: int
    is_leaky: bool
    prev_x: int
    prev_y: int
    prev_orientation: int
    trace_history: List[TraceHistory]
    trace_style: str
    trace_color: str
    id: int
    initial_position: List[int]

    def __init__(self, x: int, y: int, objects: Objects, model: str, orientation: int, is_leaky: bool, prev_x: int, prev_y: int, prev_orientation: int, trace_history: List[TraceHistory], trace_style: str, trace_color: str, id: int, initial_position: List[int]) -> None:
        self.x = x
        self.y = y
        self.objects = objects
        self.model = model
        self.orientation = orientation
        self.is_leaky = is_leaky
        self.prev_x = prev_x
        self.prev_y = prev_y
        self.prev_orientation = prev_orientation
        self.trace_history = trace_history
        self.trace_style = trace_style
        self.trace_color = trace_color
        self.id = id
        self.initial_position = initial_position


class Tile(Enum):
    GRASS = "grass"
    MUD = "mud"
    THE_000000 = "#000000"


class Wall(Enum):
