    def __init__(self, walls: Dict[str, List[Wall]], small_tiles: bool, rows: int, cols: int, tiles: Dict[str, List[Tile]], goal: Goal, robots: List[Robot], description: List[str]) -> None:
        self.walls = walls
        self.small_tiles = small_tiles
        self.rows = rows
        self.cols = cols
        self.tiles = tiles
        self.goal = goal
        self.robots = robots
